// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// 指定生成器，这里是 Prisma Client for JavaScript
generator client {
  provider = "prisma-client-js"
  output   = "./generated/client" // 自定义输出目录，便于版本控制和 Docker 打包
}

// 定义数据源，这里使用 SQLite
datasource db {
  provider = "sqlite"
}

// 部门表 (树状结构)
model Organization {
  id          String  @id @default(uuid()) // 主键
  name        String // 部门名称
  parentId    String? // 父部门ID，根节点为空
  description String? // 描述

  // 自关联关系
  parent   Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children Organization[] @relation("OrgHierarchy")

  // 与用户表的关联
  users User[]

  createTime DateTime @default(now()) // 创建时间
  updateTime DateTime @updatedAt // 最后更新时间
  delete     Int      @default(0) // 软删除，0表示未删除，1表示已删除

  @@index([parentId, delete])
}

// 角色表
model Role {
  id             String     @id @default(uuid()) // 主键ID（UUID）
  code           String     @unique // 角色编码（唯一，如: admin），用于系统逻辑判断
  displayName    String // 角色显示名称（如: 系统管理员）
  description    String? // 角色描述
  isSystem       Boolean    @default(false) // 是否为系统内置角色（不可删除）
  permissionKeys Json       @default("[]") // 允许访问的稳定权限 key（JSON数组）
  userRoles      UserRole[] // 关联到用户角色绑定表
  createTime     DateTime   @default(now()) // 创建时间
  updateTime     DateTime   @updatedAt // 最后更新时间
  delete         Int        @default(0) // 软删除标记，0表示未删除，1表示已删除

  @@index([id])
  @@index([displayName, delete])
}

// 用户表
model User {
  id             String        @id @default(uuid()) // 主键ID（UUID）
  username       String // 用户名（唯一）
  displayName    String // 用户显示姓名
  isSystem       Boolean       @default(false) // 是否为系统内置用户（不可删除）
  phone          String? // 电话号码（可选）
  password       String // 密码（加密存储）
  organizationId String? // 所属组织ID
  organization   Organization? @relation(fields: [organizationId], references: [id]) // 关联到组织表
  userRoles      UserRole[] // 用户角色绑定关系
  createTime     DateTime      @default(now()) // 创建时间
  updateTime     DateTime      @updatedAt // 最后更新时间
  delete         Int           @default(0) // 软删除标记，0表示未删除，1表示已删除

  @@unique([username, delete]) // 用户名在未删除状态下唯一
  @@index([id])
  @@index([username, delete])
}

// 用户-角色绑定表
model UserRole {
  id         String   @id @default(uuid()) // 绑定记录主键ID
  userId     String // 用户ID
  roleId     String // 角色ID
  createTime DateTime @default(now()) // 绑定创建时间

  user User @relation(fields: [userId], references: [id]) // 所属用户
  role Role @relation(fields: [roleId], references: [id]) // 所属角色

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// 文章管理表
model Article {
  id         String      @id @default(uuid()) // 主键ID
  title      String // 文章标题
  content    String // 文章内容
  images     Json        @default("[]") // 文章内包含的图片 为图片id组成的数组
  createTime DateTime    @default(now()) // 创建时间
  updateTime DateTime    @updatedAt // 最后更新时间
  type       ArticleType @default(NORMAL) // 文章类型
  delete     Int         @default(0) // 软删除标记，0表示未删除，1表示已删除

  @@index([id, delete])
  @@index([type, delete])
}

enum ArticleType {
  NORMAL
}

// 文章展示顺序排布表
model ArticleOrder {
  id         String   @id @default(uuid()) // 主键ID
  page       String // 对应页面key
  articles   Json     @default("[]") //包含的所有文章 为文章id组成的数组
  createTime DateTime @default(now()) // 创建时间
  updateTime DateTime @updatedAt // 最后更新时间
  delete     Int      @default(0) // 软删除标记，0表示未删除，1表示已删除

  @@index([page, delete])
}

// 上传的图片
model Image {
  id           String   @id @default(uuid()) // 图片主键ID
  filename     String   @unique // 生成的文件名
  originalName String // 原始文件名
  hash         String // 文件哈希值
  createdAt    DateTime @default(now()) // 创建时间
  updatedAt    DateTime @updatedAt // 最后更新时间
  delete       Int      @default(0) // 软删除标记，0表示未删除，1表示已删除

  @@unique([hash, delete])
  @@index([id, delete])
}
